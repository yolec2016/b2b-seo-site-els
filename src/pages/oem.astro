---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="OEM & ODM Small Kitchen Appliance Manufacturer for B2B Buyers"
  description="OEM and ODM manufacturing for electric kettles, rice cookers, pressure cookers and portable lunch boxes. China factory support for importers and private label brands."
>

<!-- HERO (same style as FAQ) -->
<section class="hero">
  <div class="container">
    <h1>OEM & ODM Small Kitchen Appliance Manufacturing</h1>

    <p>
      China factory support for B2B buyers sourcing electric kettles, rice cookers,
      pressure cookers and portable lunch boxes. We help importers, distributors
      and private label brands move from sample approval to mass production.
    </p>
  </div>
</section>

<!-- CONTENT -->
<section class="faq">
  <div class="container">

    <!-- NAV -->
    <div class="faq-nav">
      <a href="#services">Services</a>
      <a href="#process">Process</a>
      <a href="#capability">Factory</a>
      <a href="#whyus">Why Us</a>
    </div>

    <!-- SERVICES -->
    <h2 id="services">OEM & ODM Services for B2B Appliance Projects</h2>

    <details class="faq-item">
      <summary>OEM Manufacturing for Confirmed Product Specifications</summary>
      <p>
        We manufacture small kitchen appliances based on your confirmed model,
        technical specifications, branding requirements and packaging standards.
        This is suitable for repeat purchasing programs and existing product ranges.
      </p>
    </details>

    <details class="faq-item">
      <summary>ODM Development for New Appliance Lines</summary>
      <p>
        Our R&D and engineering team supports product structure review, appearance
        customization, mold development and model selection for new electric kettle,
        rice cooker, pressure cooker and portable lunch box projects.
      </p>
    </details>

    <details class="faq-item">
      <summary>Private Label and Retail-Ready Packaging</summary>
      <p>
        We provide logo printing, product color customization, packaging file
        support, carton marking and brand presentation for importers, retailers
        and regional distributors.
      </p>
    </details>

    <details class="faq-item">
      <summary>Procurement Support from Sample to Shipment</summary>
      <p>
        We support product confirmation, sample preparation, packaging approval,
        mass production, quality inspection and export shipment coordination.
      </p>
    </details>

    <!-- PROCESS -->
    <h2 id="process">OEM / ODM Process</h2>

    <details class="faq-item">
      <summary>Step 1: Requirement and Market Review</summary>
      <p>We confirm product category, target market, order quantity, plug type, packaging needs, certification requirements and delivery schedule.</p>
    </details>

    <details class="faq-item">
      <summary>Step 2: Model Selection and Sampling</summary>
      <p>We recommend suitable models or customization options, then prepare samples for buyer evaluation and internal approval.</p>
    </details>

    <details class="faq-item">
      <summary>Step 3: Logo, Packaging and Specification Confirmation</summary>
      <p>We confirm private label artwork, packaging structure, color, material, accessories and technical requirements before production.</p>
    </details>

    <details class="faq-item">
      <summary>Step 4: Mass Production and QC</summary>
      <p>Mass production is managed with raw material checks, process inspection, functional testing, appearance checks and final packing review.</p>
    </details>

    <details class="faq-item">
      <summary>Step 5: Packaging & Shipment</summary>
      <p>We prepare export packing and support EXW, FOB, CIF and other shipping terms based on buyer requirements.</p>
    </details>

    <!-- FACTORY -->
    <h2 id="capability">Factory Capability</h2>

    <details class="faq-item">
      <summary>Established in 2015</summary>
      <p>More than 10 years of small kitchen appliance manufacturing experience for B2B buyers and brand owners.</p>
    </details>

    <details class="faq-item">
      <summary>Production Capacity</summary>
      <p>200+ workers and 3 production lines support stable output for electric kettles, rice cookers, pressure cookers and portable lunch boxes.</p>
    </details>

    <details class="faq-item">
      <summary>In-house Workshops</summary>
      <p>Metal stamping, injection molding and assembly capabilities help improve project communication and production control.</p>
    </details>

    <details class="faq-item">
      <summary>Quality System</summary>
      <p>An independent QC team checks materials, production, function, appearance and packaging before shipment.</p>
    </details>

    <details class="faq-item">
      <summary>Certifications</summary>
      <p>CE, RoHS and LFGB support is available depending on the product model and target market requirements.</p>
    </details>

    <!-- WHY US -->
    <h2 id="whyus">Why Choose Us</h2>

    <details class="faq-item">
      <summary>Direct China Factory Communication</summary>
      <p>Procurement teams can communicate directly with the manufacturer about price, samples, packaging, production and inspection.</p>
    </details>

    <details class="faq-item">
      <summary>Focused Product Categories</summary>
      <p>Our focused product range makes sourcing easier for buyers who need electric kettles, rice cookers, pressure cookers and portable lunch boxes.</p>
    </details>

    <details class="faq-item">
      <summary>Export Experience</summary>
      <p>We support buyers from Europe, the Middle East, Southeast Asia and other global markets with export packing and document coordination.</p>
    </details>

    <!-- CTA -->
    <div class="cta">
      <h2>Start Your OEM or ODM Appliance Project</h2>

      <p>
        Send your target product, quantity, market, logo, packaging and compliance
        requirements. Our team will reply with practical sourcing support within 24 hours.
      </p>

      <a href="https://www.yolec-electronics.com/contact/" class="btn">
        Get Free Quote
      </a>
    </div>

  </div>
</section>

</BaseLayout>

<!-- STYLE -->
<style>

.hero{
  position:relative;
  overflow:hidden;
  padding:110px 20px;
  text-align:center;
  background:
    linear-gradient(rgba(0,0,0,0.52), rgba(0,0,0,0.52)),
    url("/images/yolec-electric.png") center/cover no-repeat;
}

.hero h1{
  font-size:42px;
  margin-bottom:12px;
  color:#fff;
}

.hero p{
  max-width:800px;
  margin:auto;
  color:rgba(255,255,255,0.9);
  line-height:1.6;
}

.faq{
  padding:60px 20px 100px;
}

.container{
  max-width:1100px;
  margin:auto;
}

.faq-nav{
  display:flex;
  justify-content:center;
  flex-wrap:wrap;
  gap:10px;
  margin-bottom:50px;
}

.faq-nav a{
  padding:8px 14px;
  border:1px solid #e5e5e5;
  border-radius:30px;
  text-decoration:none;
  font-size:14px;
  color:#333;
  transition:0.3s;
}

.faq-nav a:hover{
  background:#111;
  color:#fff;
}

h2{
  font-size:24px;
  margin:45px 0 20px;
  text-align:left;
}

.faq-item{
  background:#fff;
  border:1px solid #eee;
  border-radius:12px;
  padding:16px 18px;
  margin-bottom:12px;
  transition:0.3s;
}

.faq-item:hover{
  box-shadow:0 8px 20px rgba(0,0,0,0.06);
}

summary{
  cursor:pointer;
  font-weight:600;
  font-size:16px;
  list-style:none;
}

summary::-webkit-details-marker{
  display:none;
}

.faq-item p{
  margin-top:10px;
  color:#555;
  line-height:1.6;
  font-size:14px;
}

.cta{
  margin-top:70px;
  padding:50px 30px;
  text-align:center;
  background:#f5f6f8;
  border-radius:16px;
}

.cta h2{
  text-align:center;
  margin-bottom:10px;
}

.cta p{
  max-width:700px;
  margin:0 auto 20px;
  color:#555;
}

.btn{
  display:inline-block;
  padding:12px 22px;
  background:#ff6600;
  color:#fff;
  text-decoration:none;
  border-radius:6px;
  font-weight:600;
}

@media (max-width:768px){
  .hero{
    padding:90px 20px;
  }

  .hero h1{
    font-size:32px;
  }

  h2{
    font-size:20px;
  }
}

</style>
