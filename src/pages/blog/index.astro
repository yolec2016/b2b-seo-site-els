---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSortedPosts } from "../../data/blog-posts";

const posts = getSortedPosts();
---

<BaseLayout
  title="Kitchen Appliance Industry Blog"
  description="OEM & ODM manufacturing insights, sourcing guides and factory knowledge."
>

<section class="hero">

  <div class="container">

    <h1>Kitchen Appliance Industry Blog</h1>

    <p>
      Insights, sourcing guides and manufacturing knowledge for global buyers.
    </p>

  </div>

</section>

<section class="blog-list">

<div class="container">

<h2>Latest Articles</h2>

<div class="posts">

{
  posts.map((post) => (
    <article class="post">
      <h3>
        <a href={`/blog/${post.slug}`}>
          {post.title}
        </a>
      </h3>
      <p>
        {post.description}
      </p>
      <p class="meta">
        {post.category}
      </p>
    </article>
  ))
}

</div>

</div>

</section>

</BaseLayout>

<style>

.hero{

padding:110px 20px;

text-align:center;

background:
  linear-gradient(rgba(0,0,0,0.52), rgba(0,0,0,0.52)),
  url('/images/yolec-electric.png') center/cover no-repeat;

position: relative;

overflow:hidden;

}

.hero::before{

display:none;

}

.hero .container{

position: relative;

z-index: 1;

}

.hero h1{

color:#fff;

}

.hero p{

color:rgba(255,255,255,0.9);

}

.blog-list{

padding:80px 20px;

}

.posts{

display:grid;

gap:30px;

margin-top:40px;

}

.post{

padding:35px;

border:1px solid #ececec;

border-radius:12px;

transition:.3s;

}

.post:hover{

box-shadow:0 10px 25px rgba(0,0,0,.06);

}

.post a{

text-decoration:none;

color:#222;

}

.post h3{

margin-bottom:15px;

}

.meta{

margin-top:15px;

font-size:14px;

color:#888;

}

/* Mobile styles */
@media (max-width: 768px){
    .hero{
        padding:90px 15px;
    }
    
    .hero h1{
        font-size:32px;
    }
    
    .hero p{
        font-size:16px;
    }
    
    .blog-list{
        padding:50px 15px;
    }
    
    .posts{
        gap:20px;
        margin-top:30px;
    }
    
    .post{
        padding:25px;
    }
    
    .post h3{
        font-size:20px;
    }
}

@media (max-width: 480px){
    .hero h1{
        font-size:28px;
    }
    
    .post{
        padding:20px;
    }
}

</style>
