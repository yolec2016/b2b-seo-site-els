---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Китайский производитель мелкой кухонной техники | OEM и ODM",
  description = "Китайский производитель электрических чайников, чайников для кофе, рисоварок, электрических скороварок и другой мелкой кухонной техники. OEM и ODM производство для международных B2B-покупателей."
} = Astro.props;

const canonical = Astro.url.href;
---

<!DOCTYPE html>
<html lang="ru">

<head>

    <meta charset="UTF-8" />

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    />

    <title>{title}</title>

    <meta
        name="description"
        content={description}
    />

    <!-- SEO -->
    <meta name="robots" content="index,follow,max-image-preview:large" />

    <meta
        name="keywords"
        content="производитель мелкой кухонной техники, производитель бытовой техники Китай, OEM производитель, ODM производитель, электрические чайники, чайник для кофе, рисоварка, электрическая скороварка, ланч-бокс с подогревом, кухонная техника оптом, поставщик бытовой техники Китай"
    />

    <meta
        name="author"
        content="YOLEC Electric"
    />

    <meta
        http-equiv="Content-Language"
        content="ru"
    />

    <meta
        name="theme-color"
        content="#0070f3"
    />

    <!-- Canonical -->
    <link
        rel="canonical"
        href={canonical}
    />

    <!-- hreflang -->
    <link
        rel="alternate"
        hreflang="ru"
        href={canonical}
    />

    <!-- Open Graph -->
    <meta
        property="og:type"
        content="website"
    />

    <meta
        property="og:locale"
        content="ru_RU"
    />

    <meta
        property="og:title"
        content={title}
    />

    <meta
        property="og:description"
        content={description}
    />

    <meta
        property="og:url"
        content={canonical}
    />

    <meta
        property="og:site_name"
        content="YOLEC Electric"
    />

    <meta
        property="og:image"
        content="/images/yolec-electric.png"
    />

    <!-- Twitter -->
    <meta
        name="twitter:card"
        content="summary_large_image"
    />

    <meta
        name="twitter:title"
        content={title}
    />

    <meta
        name="twitter:description"
        content={description}
    />

    <meta
        name="twitter:image"
        content="/images/yolec-electric.png"
    />

    <!-- CSS -->
    <link rel="stylesheet" href="/css/global.css" />

</head>

<body>

    <Header />

    <main>

        <slot />

    </main>

    <Footer />

</body>

</html>