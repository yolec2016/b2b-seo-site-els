---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "China Small Kitchen Appliance Manufacturer | OEM & ODM",
  description = "Professional China manufacturer of electric kettles, coffee kettles, rice cookers, pressure cookers and other small kitchen appliances."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8" />

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    />

    <title>{title}</title>

    <meta
        name="description"
        content={description}
    />

    <link rel="stylesheet" href="/css/global.css" />

</head>

<body>

    <Header />

    <main>

        <slot />

    </main>

    <Footer />

</body>

</html>