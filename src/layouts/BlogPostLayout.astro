---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
>

<section class="article-hero">

  <div class="container">

    <a href="/blog" class="back-link">← Вернуться к блогу</a>

    <h1>{frontmatter.title}</h1>

    <div class="meta">

      <span class="category">
        {frontmatter.category}
      </span>

      <span class="date">
        {new Date(frontmatter.pubDate).toLocaleDateString("ru-RU", {
          year: "numeric",
          month: "long",
          day: "numeric"
        })}
      </span>

      <span class="author">
        Автор: {frontmatter.author}
      </span>

    </div>

  </div>

</section>

<section class="article-content">

  <div class="container">

    <slot />

    {frontmatter.tags && frontmatter.tags.length > 0 && (

      <div class="tags">

        <strong>Теги:</strong>

        {frontmatter.tags.map((tag: string) => (

          <span class="tag">{tag}</span>

        ))}

      </div>

    )}

  </div>

</section>

</BaseLayout>

<style>

.article-hero{

padding:90px 20px 60px;

text-align:center;

border-bottom:1px solid #ececec;

}

.back-link{

display:inline-block;

margin-bottom:30px;

color:#666;

text-decoration:none;

font-size:14px;

}

.back-link:hover{

color:#222;

}

.meta{

margin-top:20px;

display:flex;

gap:20px;

justify-content:center;

flex-wrap:wrap;

font-size:14px;

color:#888;

}

.category{

background:#f0f0f0;

padding:4px 12px;

border-radius:20px;

}

.article-content{

padding:60px 20px;

}

.article-content :global(h2){

margin-top:40px;

margin-bottom:20px;

}

.article-content :global(p){

margin-bottom:20px;

line-height:1.8;

}

.tags{

margin-top:40px;

padding-top:30px;

border-top:1px solid #ececec;

display:flex;

gap:10px;

align-items:center;

flex-wrap:wrap;

}

.tag{

background:#f0f0f0;

padding:4px 12px;

border-radius:20px;

font-size:13px;

}

</style>